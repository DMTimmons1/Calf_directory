<div class="page">
  <% if notice %>
    <div class="flash flash-notice"><%= notice %></div>
  <% end %>

  <% if alert %>
    <div class="flash flash-alert"><%= alert %></div>
  <% end %>

  <div class="header">
    <div>
      <h1 class="page-title"><%= @calf.name %></h1>
      <p class="subtle">
        <span class="status-badge <%= status_class(@calf) %>">
          <%= @calf.status.titleize %>
        </span>
      </p>
    </div>

    <div class="header-actions">
      <%= link_to "Back", calves_path, class: "btn btn-outline btn-full" %>
    </div>
  </div>

  <div class="stats">
    <div class="stat-card">
      <div class="stat-label">Current Weight</div>
      <div class="stat-value">
        <%= @calf.weight_lbs.present? ? "#{@calf.weight_lbs} lbs" : "—" %>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-label">Status</div>
      <div class="stat-value"><%= @calf.status.titleize %></div>
    </div>

    <% if @calf.birthdate.present? %>
      <div class="stat-card">
        <div class="stat-label">Birthdate</div>
        <div class="stat-value"><%= @calf.birthdate.strftime("%b %d, %Y") %></div>
      </div>
    <% end %>
  </div>

  <div class="action-row">
  <%= link_to "Edit Calf",
              edit_calf_path(@calf),
              class: "btn btn-primary" %>

  <%= button_to "Delete Calf",
                calf_path(@calf),
                method: :delete,
                data: { turbo_confirm: "Delete this calf? This can’t be undone." },
                class: "btn btn-danger",
                form_class: "delete-form" %>
  </div>

  <details class="panel">
    <summary class="panel-summary">Add Medication Event</summary>

    <div class="panel-body">
      <%= form_with scope: :calf_event,
                    url: calf_medication_path(@calf),
                    method: :post,
                    local: true,
                    class: "form" do |f| %>

        <div class="field">
          <%= f.label :medication_name, "Medication name", class: "label" %>
          <%= f.text_field :medication_name, required: true, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :dose, "Dose (optional)", class: "label" %>
          <%= f.text_field :dose, class: "input" %>
        </div>

        <div class="field">
          <%= f.label :occurred_at, "Occurred at (optional)", class: "label" %>
          <%= f.datetime_local_field :occurred_at, class: "input" %>
          <div class="help-text">Leave blank to use the current time.</div>
        </div>

        <div class="field">
          <%= f.label :note, "Note (optional)", class: "label" %>
          <%= f.text_area :note, rows: 3, class: "input" %>
        </div>

        <%= f.submit "Save Medication Event", class: "btn btn-primary btn-full" %>
      <% end %>
    </div>
  </details>

  <h2 class="section-title">Timeline</h2>

  <% if @calf_events.any? %>
    <% @calf_events.group_by { |e| e.occurred_at.to_date }.each do |date, events| %>
      <h3 class="timeline-date">
        <% if date == Date.current %>
          Today
        <% elsif date == Date.yesterday %>
          Yesterday
        <% else %>
          <%= date.strftime("%b %d, %Y") %>
        <% end %>
      </h3>

      <ul class="timeline">
        <% events.each do |event| %>
          <li class="timeline-card">
            <div class="timeline-top">
              <div class="timeline-time">
                <%= event.occurred_at.strftime("%I:%M %p") %>
              </div>

              <% if event.event_type.present? %>
                <span class="pill"><%= event.event_type.to_s.titleize %></span>
              <% end %>
            </div>

            <div class="timeline-body">
              <%= event.description %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% else %>
    <p class="subtle">No events yet.</p>
  <% end %>
</div>